# Copy to `.env` and adjust. Used by docker-compose.

# Port the site is served on (http://localhost:<WEB_PORT>)
WEB_PORT=8080

# Background-removal model:
#   birefnet-general   – best general quality (~1 GB)
#   birefnet-portrait  – tuned for people / ID photos
#   isnet-general-use  – lighter / faster (~170 MB)
BG_MODEL=birefnet-general

# Soft hair-edge refinement (1 = on, 0 = off/faster on CPU)
ALPHA_MATTING=1

# Max concurrent model inferences (protects CPU/RAM)
MAX_CONCURRENCY=2

# Max upload size in bytes (default 20 MB)
MAX_UPLOAD_BYTES=20971520

# Allowed CORS origins (comma-separated). Behind the bundled nginx the API is
# same-origin, so this can stay "*"; restrict it if the API is exposed directly.
CORS_ORIGINS=*

LOG_LEVEL=INFO
